# For @iot4b.ca use mail.iot4b.ca (smtp.iot4b.ca does not exist in DNS).
# MAIL_HOST=mail.iot4b.ca
# MAIL_PORT=587
# MAIL_USERNAME=no-reply@iot4b.ca
# MAIL_PASSWORD=your-mailbox-password
# MAIL_ENCRYPTION=tls
