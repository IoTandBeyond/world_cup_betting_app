APP_NAME="World Cup Pool"
APP_ENV=local
APP_URL=http://localhost:8000

# APP_BASE_PATH=worldcuppoll

DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=world_cup_poll_db
